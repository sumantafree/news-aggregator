APP_NAME=NewsAggregator
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg2://news:news@localhost:5432/newsdb

# Redis (optional; falls back to in-memory)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# RSS refresh interval (seconds)
RSS_REFRESH_INTERVAL=600
CACHE_TTL_SECONDS=600

# Frontend site URL (used for sitemap/hreflang)
SITE_URL=http://localhost:3000

# Shared secret for /cron/refresh (set this in Render Cron job too). Leave empty to disable.
CRON_SECRET=
